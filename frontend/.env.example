# Copy this file to .env and fill in the values for deployment

# The URL of your deployed backend service (e.g., on Render)
# For local frontend-only development connecting to prod backend, you can set this.
# For full-stack local development (running backend on port 5005), leave this out or let the Vite proxy handle it.
VITE_API_BASE_URL=https://weather-app-youralias.onrender.com
